# ══════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — CASATIC Directorio 2026
# Copia este archivo como .env y rellena los valores reales.
# ⚠️  NUNCA subir el .env real a Git.
# ══════════════════════════════════════════════════════════════

# --- PostgreSQL ---
POSTGRES_USER=tu_usuario_bd
POSTGRES_PASSWORD=tu_password_seguro
POSTGRES_DB=casatic_directorio

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=tu_email@dominio.com
PGADMIN_DEFAULT_PASSWORD=tu_password_pgadmin

# --- Backend API (.NET) ---
ASPNETCORE_ENVIRONMENT=Development
CONNECTION_STRING=Host=db;Port=5432;Database=casatic_directorio;Username=tu_usuario_bd;Password=tu_password_seguro;Client Encoding=UTF8
JWT_KEY=genera-una-clave-secreta-de-al-menos-32-caracteres
JWT_ISSUER=CasaticDirectorio
JWT_AUDIENCE=CasaticDirectorioClients
