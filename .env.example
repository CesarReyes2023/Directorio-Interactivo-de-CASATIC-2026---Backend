ASPNETCORE_ENVIRONMENT=Production

# Railway PostgreSQL usually provides this value. Keep it secret.
CONNECTION_STRING=Host=YOUR_HOST;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

JWT_KEY=CHANGE_ME_GENERATE_RANDOM_min_32_chars
JWT_ISSUER=CasaticDirectorio
JWT_AUDIENCE=CasaticDirectorioClients
JWT_EXPIRE_MINUTES=60

# Set this to your Vercel domain after frontend deployment.
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

SEED_ADMIN_EMAIL=admin@casatic.org
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
SKIP_SEED=false
